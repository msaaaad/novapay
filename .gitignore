# Dependencies — never commit node_modules
node_modules/

# Compiled output — generated by tsc, not source
dist/
build/

# Test coverage reports
coverage/

# Environment files — contain secrets, never commit
.env
.env.local
.env.production

# TypeScript build info cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
*.log

# OS files
.DS_Store
Thumbs.db

# Docker volumes (if accidentally created locally)
postgres-data/

# VS Code workspace settings (optional — remove if you want to commit these)
.vscode/